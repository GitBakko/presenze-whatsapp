# ── Database ──
# SQLite file path (relativo alla root del progetto)
DATABASE_URL="file:./dev.db"

# ── Autenticazione ──
# Secret per firmare i JWT — genera con: openssl rand -base64 32
NEXTAUTH_SECRET=""

# URL base dell'applicazione
NEXTAUTH_URL="http://localhost:3000"

# ── Registrazione ──
# Secret richiesto per creare nuovi utenti admin
SYSTEM_REGISTRATION_SECRET=""

# ── Bot Telegram (opzionale) ──
# Token del bot ottenuto da @BotFather
TELEGRAM_BOT_TOKEN=""
# Secret opaco inserito nell'URL del webhook Telegram → verificato dal server
# Genera con: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=""

# ── Email ingest via Microsoft Graph (opzionale) ──
# Acquisizione automatica delle richieste ferie inviate via email.
# Usa OAuth2 client credentials flow (non username/password) perche'
# Microsoft ha deprecato Basic Auth su IMAP/SMTP.
#
# Setup Azure AD:
#   1. Portal → Azure AD → App registrations → New registration
#      Name: HR Presenze Mail Ingest, single tenant
#   2. Certificates & secrets → New client secret → copia il Value
#   3. API permissions → Microsoft Graph → Application permissions:
#        - Mail.ReadWrite
#        - Mail.Send
#      → Grant admin consent for <tuo-tenant>
#   4. Prendi Tenant ID e Client ID dalla pagina Overview
#
# Se questi 4 valori non sono compilati, il poller non parte e tutto il
# resto dell'app funziona normalmente.
MAIL_TENANT_ID=""
MAIL_CLIENT_ID=""
MAIL_CLIENT_SECRET=""
# UPN o alias primario della mailbox target (es. hr@epartner.it)
MAIL_MAILBOX=""
# Nome della sottocartella in cui le mail con oggetto "ferie" vengono
# spostate (via regola M365 server-side). Default "Ferie".
MAIL_FOLDER="Ferie"
# Intervallo tra due polling in secondi
MAIL_POLL_INTERVAL_SEC="120"
# Display name usato come "name" del mittente nelle reply automatiche
MAIL_REPLY_FROM=""
