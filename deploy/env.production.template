# .env di produzione — copiare come `.env` nella cartella del deploy
# (E:\HR\app\.env) e compilare tutti i campi.

# ── Database SQLite ──
# Il file fisico vive FUORI dalla cartella del deploy, cosi' un
# redeploy non lo sovrascrive.
DATABASE_URL="file:E:/HR/data/prod.db"

# ── NextAuth ──
# Genera un nuovo secret con: [System.Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
# da un prompt PowerShell. Valore BASE64 lungo 44 caratteri.
NEXTAUTH_SECRET=""

# URL pubblico, deve corrispondere al binding IIS
NEXTAUTH_URL="https://hr.epartner.it"

# ── Registrazione ──
# Secret richiesto per creare nuovi utenti admin via POST /api/register.
# Va valorizzato SOLO per creare il primo admin, poi si puo' svuotare
# (ma non rimuovere la riga, serve come variabile).
SYSTEM_REGISTRATION_SECRET=""

# ── Runtime ──
# Porta su cui il servizio Node ascolta in locale. IIS la userà come
# upstream tramite ARR (vedi iis-web.config).
PORT=3100
HOSTNAME=127.0.0.1

# Forza il runtime in production mode
NODE_ENV=production

# ── Bot Telegram (opzionale) ──
# Token del bot generato da @BotFather.
# Se vuoto, il bot e' disattivato ma l'app gira lo stesso.
TELEGRAM_BOT_TOKEN=""
# Secret opaco nell'URL del webhook Telegram. Genera con:
# [System.Convert]::ToHexString([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
TELEGRAM_WEBHOOK_SECRET=""

# ── Email ingest IMAP (opzionale) ──
# Poller che ogni MAIL_POLL_INTERVAL_SEC controlla la casella configurata
# per richieste ferie con oggetto "ferie" e body "DAL ... AL ...".
# Se HOST/USER/PASSWORD mancano, il poller non parte e l'app continua
# a funzionare normalmente.
MAIL_IMAP_HOST=""
MAIL_IMAP_PORT=993
MAIL_IMAP_USER=""
MAIL_IMAP_PASSWORD=""
MAIL_IMAP_TLS=true
MAIL_IMAP_FOLDER=INBOX
MAIL_POLL_INTERVAL_SEC=120

# ── Email reply SMTP (opzionale) ──
# Se configurato, il sistema risponde al mittente con:
#   - conferma acquisizione richiesta
#   - errore di parsing spiegato
#   - avviso mittente non autorizzato
# E invia notifiche al dipendente su approve/reject delle ferie.
# Se mancano, l'ingest IMAP continua a funzionare ma senza reply.
MAIL_SMTP_HOST=""
MAIL_SMTP_PORT=587
MAIL_SMTP_USER=""
MAIL_SMTP_PASSWORD=""
# "true" => SSL diretto su 465; "false" o vuoto => STARTTLS su 587
MAIL_SMTP_SECURE=false
# Indirizzo "From:" nelle email in uscita (se vuoto usa MAIL_SMTP_USER)
MAIL_REPLY_FROM="HR Presenze <ferie@epartner.it>"
