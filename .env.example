# ── Database ──
# SQLite file path (relativo alla root del progetto)
DATABASE_URL="file:./dev.db"

# ── Autenticazione ──
# Secret per firmare i JWT — genera con: openssl rand -base64 32
NEXTAUTH_SECRET=""

# URL base dell'applicazione
NEXTAUTH_URL="http://localhost:3000"

# ── Registrazione ──
# Secret richiesto per creare nuovi utenti admin
SYSTEM_REGISTRATION_SECRET=""

# ── Bot Telegram (opzionale) ──
# Token del bot ottenuto da @BotFather
TELEGRAM_BOT_TOKEN=""
# Secret opaco inserito nell'URL del webhook Telegram → verificato dal server
# Genera con: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=""

# ── Email ingest IMAP (opzionale) ──
# Se non configurato, il poller IMAP non parte e il resto dell'app funziona
# normalmente. Host/User/Password sono obbligatori per attivarlo.
MAIL_IMAP_HOST=""
MAIL_IMAP_PORT="993"
MAIL_IMAP_USER=""
MAIL_IMAP_PASSWORD=""
MAIL_IMAP_TLS="true"
MAIL_IMAP_FOLDER="INBOX"
# Intervallo tra due polling in secondi
MAIL_POLL_INTERVAL_SEC="120"

# ── Email reply SMTP (opzionale) ──
# Se non configurato, l'ingest IMAP continua a funzionare ma senza reply
# automatiche ai dipendenti (mittente sconosciuto, formato errato, conferma).
MAIL_SMTP_HOST=""
MAIL_SMTP_PORT="587"
MAIL_SMTP_USER=""
MAIL_SMTP_PASSWORD=""
# "true" => SSL diretto su 465; "false" o vuoto => STARTTLS su 587
MAIL_SMTP_SECURE="false"
# Indirizzo "From:" nelle email in uscita. Se vuoto usa MAIL_SMTP_USER.
MAIL_REPLY_FROM="HR Presenze <ferie@epartner.it>"
