<?xml version="1.0" encoding="UTF-8"?>
<!--
  web.config per il sito IIS che funge da reverse proxy verso il servizio
  Node/Next.js in ascolto su localhost:3100.

  Prerequisiti sul server:
    1. IIS con ARR (Application Request Routing) installato e la
       "Reverse Proxy" abilitata a livello di server (spuntata in
       ARR -> Server Proxy Settings -> Enable proxy).
    2. URL Rewrite module installato.
    3. Un sito IIS "presenze-hr" con binding https://hr.epartner.it:443.
    4. Il servizio Node (NSSM) in esecuzione sulla porta 3100.

  Messo in C:\inetpub\wwwroot\presenze-hr\web.config (root del sito).
-->
<configuration>
  <system.webServer>

    <rewrite>
      <rules>
        <!-- HTTP -> HTTPS: se IIS accetta HTTP sullo stesso binding,
             redirige tutto a HTTPS. Puoi rimuovere questa rule se il
             sito e' solo-HTTPS a livello di binding. -->
        <rule name="ForceHTTPS" stopProcessing="true">
          <match url="(.*)" />
          <conditions logicalGrouping="MatchAll">
            <add input="{HTTPS}" pattern="^OFF$" />
          </conditions>
          <action type="Redirect"
                  url="https://{HTTP_HOST}/{R:1}"
                  redirectType="Permanent" />
        </rule>

        <!-- Reverse proxy verso Node su localhost:3100 -->
        <rule name="ReverseProxyToNode" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite"
                  url="http://127.0.0.1:3100/{R:1}" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_PROTO" value="https" />
            <set name="HTTP_X_FORWARDED_HOST" value="{HTTP_HOST}" />
            <set name="HTTP_X_FORWARDED_FOR" value="{REMOTE_ADDR}" />
          </serverVariables>
        </rule>
      </rules>

      <!-- Permetti a Rewrite di impostare le server variables usate sopra.
           IIS per default blocca la scrittura delle HTTP_* custom. -->
      <allowedServerVariables>
        <add name="HTTP_X_FORWARDED_PROTO" />
        <add name="HTTP_X_FORWARDED_HOST" />
        <add name="HTTP_X_FORWARDED_FOR" />
      </allowedServerVariables>
    </rewrite>

    <!-- Disabilita il buffering della risposta: necessario per Server-Sent
         Events (/api/notifications/stream). Senza queste righe la
         campanella notifiche non si aggiorna in produzione perche' IIS
         accumula i chunk prima di inoltrarli al client. -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Accel-Buffering" value="no" />
      </customHeaders>
    </httpProtocol>

    <serverRuntime enabled="true" uploadReadAheadSize="0" />

    <!-- ARR: disabilita il buffering di richiesta e risposta per abilitare
         lo streaming (SSE) e upload di grandi file senza carico di
         memoria extra. -->
    <proxy xmlns="urn:microsoft.web.arr:proxy" enabled="true"
           preserveHostHeader="true" reverseRewriteHostInResponseHeaders="true" />

    <!-- Aumenta il limite di upload a 25 MB per gli avatar e import .txt
         WhatsApp. -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="26214400" />
      </requestFiltering>
    </security>

    <!-- Timeout piu' lunghi per SSE (connessioni long-lived). -->
    <httpRuntime executionTimeout="3600" />

  </system.webServer>

  <!-- IIS nasconde X-Powered-By di Next. Aggiungiamo questo per sicurezza. -->
  <system.web>
    <httpRuntime maxRequestLength="25600" executionTimeout="3600" />
  </system.web>

</configuration>
