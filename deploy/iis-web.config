<?xml version="1.0" encoding="UTF-8"?>
<!--
  web.config per il sito IIS che funge da reverse proxy verso il servizio
  Node/Next.js in ascolto su localhost:3100.

  Prerequisiti sul server:
    1. IIS con ARR (Application Request Routing) installato e la
       "Reverse Proxy" abilitata a livello di server (ARR -> Server
       Proxy Settings -> Enable proxy).
    2. URL Rewrite module installato.
    3. Le tre server variables custom devono essere ALLOWLISTED a
       livello di applicationHost (NON nel web.config locale, IIS
       blocca la sezione). Da prompt admin:

         "%windir%\system32\inetsrv\appcmd.exe" set config -section:system.webServer/rewrite/allowedServerVariables /+"[name='HTTP_X_FORWARDED_PROTO']" /commit:apphost
         "%windir%\system32\inetsrv\appcmd.exe" set config -section:system.webServer/rewrite/allowedServerVariables /+"[name='HTTP_X_FORWARDED_HOST']" /commit:apphost
         "%windir%\system32\inetsrv\appcmd.exe" set config -section:system.webServer/rewrite/allowedServerVariables /+"[name='HTTP_X_FORWARDED_FOR']" /commit:apphost

    4. Sito IIS con binding https://hr.epartner.it:443 e physicalPath
       puntata a una cartella che contiene SOLO questo web.config
       (NON la cartella del server.js Node).
    5. Il servizio Node (NSSM) in esecuzione sulla porta 3100.
-->
<configuration>
  <system.webServer>

    <rewrite>
      <rules>
        <!-- Reverse proxy verso Node su localhost:3100 -->
        <rule name="ReverseProxyToNode" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:3100/{R:1}" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_PROTO" value="https" />
            <set name="HTTP_X_FORWARDED_HOST" value="{HTTP_HOST}" />
            <set name="HTTP_X_FORWARDED_FOR" value="{REMOTE_ADDR}" />
          </serverVariables>
        </rule>
      </rules>
    </rewrite>

    <!-- Disabilita il buffering della risposta: necessario per Server-Sent
         Events (/api/notifications/stream). Senza queste righe la
         campanella notifiche non si aggiorna in produzione perche' IIS
         accumula i chunk prima di inoltrarli al client. -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Accel-Buffering" value="no" />
      </customHeaders>
    </httpProtocol>

    <serverRuntime enabled="true" uploadReadAheadSize="0" />

    <!-- Aumenta il limite di upload a 25 MB per gli avatar e import .txt
         WhatsApp. -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="26214400" />
      </requestFiltering>
    </security>

  </system.webServer>
</configuration>
