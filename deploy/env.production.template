# .env di produzione — copiare come `.env` nella cartella del deploy
# (E:\HR\app\.env) e compilare tutti i campi.

# ── Database SQLite ──
# Il file fisico vive FUORI dalla cartella del deploy, cosi' un
# redeploy non lo sovrascrive.
DATABASE_URL="file:E:/HR/data/prod.db"

# ── NextAuth ──
# Genera un nuovo secret con: [System.Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
# da un prompt PowerShell. Valore BASE64 lungo 44 caratteri.
NEXTAUTH_SECRET=""

# URL pubblico, deve corrispondere al binding IIS
NEXTAUTH_URL="https://hr.epartner.it"

# ── Registrazione ──
# Secret richiesto per creare nuovi utenti admin via POST /api/register.
# Va valorizzato SOLO per creare il primo admin, poi si puo' svuotare
# (ma non rimuovere la riga, serve come variabile).
SYSTEM_REGISTRATION_SECRET=""

# ── Runtime ──
# Porta su cui il servizio Node ascolta in locale. IIS la userà come
# upstream tramite ARR (vedi iis-web.config).
PORT=3100
HOSTNAME=127.0.0.1

# Forza il runtime in production mode
NODE_ENV=production
