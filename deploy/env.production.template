# .env di produzione — copiare come `.env` nella cartella del deploy
# (E:\HR\app\.env) e compilare tutti i campi.

# ── Database SQLite ──
# Il file fisico vive FUORI dalla cartella del deploy, cosi' un
# redeploy non lo sovrascrive.
DATABASE_URL="file:E:/HR/data/prod.db"

# ── NextAuth ──
# Genera un nuovo secret con: [System.Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
# da un prompt PowerShell. Valore BASE64 lungo 44 caratteri.
NEXTAUTH_SECRET=""

# URL pubblico, deve corrispondere al binding IIS
NEXTAUTH_URL="https://hr.epartner.it"

# ── Registrazione ──
# Secret richiesto per creare nuovi utenti admin via POST /api/register.
# Va valorizzato SOLO per creare il primo admin, poi si puo' svuotare
# (ma non rimuovere la riga, serve come variabile).
SYSTEM_REGISTRATION_SECRET=""

# ── Runtime ──
# Porta su cui il servizio Node ascolta in locale. IIS la userà come
# upstream tramite ARR (vedi iis-web.config).
PORT=3100
HOSTNAME=127.0.0.1

# Forza il runtime in production mode
NODE_ENV=production

# ── WebSocket notifiche real-time ──
# Server WS su porta dedicata (separata da IIS) per le notifiche
# push al browser. Il client si connette direttamente qui.
# IMPORTANTE: aprire questa porta nel firewall di Windows Server.
WS_PORT=3101

# ── Bot Telegram (opzionale) ──
# Token del bot generato da @BotFather.
# Se vuoto, il bot e' disattivato ma l'app gira lo stesso.
TELEGRAM_BOT_TOKEN=""
# Secret opaco nell'URL del webhook Telegram. Genera con:
# [System.Convert]::ToHexString([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
TELEGRAM_WEBHOOK_SECRET=""

# ── Email ingest via Microsoft Graph (opzionale) ──
# Poller che ogni MAIL_POLL_INTERVAL_SEC controlla la mailbox target
# via Microsoft Graph API (OAuth2 client credentials). Usa un'app
# registration Azure AD con permessi APPLICATION:
#   - Mail.ReadWrite
#   - Mail.Send
# + admin consent.
#
# Setup Azure AD:
#   1. portal.azure.com → Azure AD → App registrations → New registration
#      Name: HR Presenze Mail Ingest, single tenant, nessun redirect URI
#   2. Certificates & secrets → New client secret → copia il Value
#      (non l'Id). Scadenza consigliata 24 mesi.
#   3. API permissions → Microsoft Graph → Application permissions:
#        - Mail.ReadWrite
#        - Mail.Send
#      → Grant admin consent
#   4. Prendi Tenant ID e Client ID dalla pagina Overview
#
# Se questi 4 valori non sono compilati, il poller non parte e tutto
# il resto dell'app funziona normalmente.
MAIL_TENANT_ID=""
MAIL_CLIENT_ID=""
MAIL_CLIENT_SECRET=""
# UPN o alias primario della mailbox target (es. hr@epartner.it)
MAIL_MAILBOX="hr@epartner.it"
# Nome della sottocartella in cui le mail con oggetto "ferie" vengono
# spostate (via regola M365 server-side). Default "Ferie".
MAIL_FOLDER="Ferie"
MAIL_POLL_INTERVAL_SEC=120
# Display name usato come "name" del mittente nelle reply automatiche
MAIL_REPLY_FROM="HR ePartner <hr@epartner.it>"
